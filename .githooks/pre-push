#!/bin/sh

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

echo "🧪 Running unit tests..."
UNIT_OUTPUT=$(go test -v -count=1 $(go list ./... | grep -v ministry-mapper/internal/setup) 2>&1)
UNIT_EXIT=$?
PASS_COUNT=$(echo "$UNIT_OUTPUT" | grep -c "^--- PASS")
FAIL_COUNT=$(echo "$UNIT_OUTPUT" | grep -c "^--- FAIL")
if [ $UNIT_EXIT -ne 0 ]; then
  echo "$UNIT_OUTPUT"
  echo "❌ Unit tests failed ($FAIL_COUNT failed). Push aborted."
  exit 1
fi
echo "✅ Unit tests passed ($PASS_COUNT passed)."

echo "🧪 Running integration tests..."
"$PROJECT_ROOT/scripts/test.sh"
if [ $? -ne 0 ]; then
  echo "❌ Integration tests failed. Push aborted."
  exit 1
fi

echo "🚀 All tests passed. Pushing..."
exit 0
